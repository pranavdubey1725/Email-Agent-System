# Copy this file to .env and fill in your values
# Never commit .env to git

# Your OpenAI API key — get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Gmail address you want to send FROM
GMAIL_USER=yourname@gmail.com

# Gmail App Password (NOT your regular password)
# Google Account → Security → 2-Step Verification → App passwords
GMAIL_APP_PASSWORD=abcdefghijklmnop

# Your deployed frontend URL — set this on Render so the backend allows CORS from Vercel
# Leave blank for local development
FRONTEND_URL=https://your-app.vercel.app

# Server port (optional, defaults to 5000)
PORT=5000
