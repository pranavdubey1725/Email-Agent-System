# Copy this file to .env and fill in your values
# Never commit .env to git

# Your OpenAI API key — get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# ── Google OAuth 2.0 ──────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Application type: Web application
# Authorised redirect URIs: add your backend /auth/google/callback URL

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# Where Google redirects after sign-in.
# Local:      http://localhost:5000/auth/google/callback
# Production: https://your-backend.onrender.com/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback

# Your deployed frontend URL — set this on Render so:
#   1. The backend allows CORS from your Vercel app
#   2. After OAuth, the backend knows where to redirect the user
# Leave blank for local development (defaults to http://localhost:5173)
FRONTEND_URL=https://your-app.vercel.app

# Server port (optional, defaults to 5000)
PORT=5000
